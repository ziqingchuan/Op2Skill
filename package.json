{
  "name": "browser-use-skill",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently -k \"pnpm dev\" \"wait-on http://127.0.0.1:5173 && pnpm electron:compile && cross-env ELECTRON_RUN_AS_NODE= NODE_ENV=development electron .\"",
    "electron:build": "pnpm electron:compile && vite build && electron-builder",
    "electron:build:win": "pnpm electron:compile && vite build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.browserrecord.app",
    "productName": "Op2Skill",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/keytar/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "electron/icon.png",
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@ant-design/icons": "5.3.7",
    "highlight.js": "11.10.0",
    "keytar": "^7.9.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "9.0.1",
    "rehype-highlight": "7.0.1",
    "remark-gfm": "^4.0.1",
    "uuid": "10.0.0",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/uuid": "10.0.0",
    "@vitejs/plugin-react": "4.3.1",
    "concurrently": "8.2.2",
    "cross-env": "7.0.3",
    "electron": "43.1.0",
    "electron-builder": "24.13.3",
    "electron-rebuild": "^3.2.9",
    "typescript": "5.5.3",
    "vite": "5.4.0",
    "wait-on": "7.2.0"
  }
}
